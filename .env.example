# ============================================================================
# Configuración de Firebase para ESTA instalación (una empresa = un proyecto)
# ----------------------------------------------------------------------------
# Cómo obtener estos valores:
#   1. Entra a https://console.firebase.google.com y abre el proyecto.
#   2. Engranaje (⚙) → Configuración del proyecto.
#   3. Baja hasta "Tus apps" → app web (</>). Si no hay, crea una.
#   4. Copia cada valor del bloque "firebaseConfig" al campo correspondiente.
#
# Luego copia este archivo a un archivo llamado  .env  (sin ".example")
# y reemplaza los valores de ejemplo por los reales.
# El archivo .env NO se sube al repositorio (está en .gitignore).
# ============================================================================

VITE_FIREBASE_API_KEY=tu_api_key
VITE_FIREBASE_AUTH_DOMAIN=tu-proyecto.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=tu-proyecto
VITE_FIREBASE_STORAGE_BUCKET=tu-proyecto.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxxxxxx
